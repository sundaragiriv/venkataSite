---
import AuthLayout from '../../../layouts/AuthLayout.astro';
---

<AuthLayout title="Signing you in..." description="Completing authentication" showSignedInRedirect={false}>
  <header class="auth-header">
    <h1>Signing you in...</h1>
    <p id="cb-msg">One moment while we complete the handshake.</p>
  </header>

  <p id="auth-error" class="auth-error" role="alert" aria-live="polite"></p>

  <p class="auth-links">
    <a href="/architect-zero/auth/sign-in">Back to sign in</a>
  </p>
</AuthLayout>

<script>
  import { supabase } from '../../../lib/supabase';
  import { consumeIntendedUrl, ensureProfile } from '../../../lib/auth';

  const errEl = document.getElementById('auth-error');
  const msgEl = document.getElementById('cb-msg');

  function fail(message: string) {
    if (msgEl) msgEl.textContent = 'Something went wrong.';
    if (errEl) errEl.textContent = message;
  }

  async function complete() {
    // detectSessionInUrl: true on the client picks up #access_token and code= automatically.
    // Give it a tick to settle, then verify.
    const { data, error } = await supabase.auth.getSession();
    if (error) {
      fail(error.message);
      return;
    }
    if (!data.session) {
      // Manual exchange if the URL has a `code` param (PKCE flow)
      const url = new URL(window.location.href);
      const code = url.searchParams.get('code');
      if (code) {
        const { error: exErr } = await supabase.auth.exchangeCodeForSession(code);
        if (exErr) {
          fail(exErr.message);
          return;
        }
      } else {
        fail('No session found after redirect. Please try signing in again.');
        return;
      }
    }

    const { data: refreshed } = await supabase.auth.getSession();
    const user = refreshed.session?.user;
    if (user) {
      // Belt and suspenders — the DB trigger should have created the profile,
      // but if it didn't (e.g. migrations not yet applied), we don't block sign-in.
      try {
        await ensureProfile(user.id);
      } catch {
        // ignore — profile creation failure shouldn't block login
      }
    }

    window.location.replace(consumeIntendedUrl());
  }

  complete();
</script>
