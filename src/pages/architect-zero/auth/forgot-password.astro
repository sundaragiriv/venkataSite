---
import AuthLayout from '../../../layouts/AuthLayout.astro';
---

<AuthLayout title="Reset password — Architect Zero" description="Reset your Architect Zero password" showSignedInRedirect={false}>
  <header class="auth-header">
    <h1>Forgot password?</h1>
    <p>Enter your email and we'll send you a reset link.</p>
  </header>

  <form id="forgot-form" novalidate>
    <label class="field">
      <span>Email</span>
      <input type="email" name="email" autocomplete="email" required placeholder="you@example.com" />
    </label>

    <p id="auth-error" class="auth-error" role="alert" aria-live="polite"></p>
    <p id="auth-info" class="auth-info" style="display:none"></p>

    <button type="submit" class="auth-submit">Send reset link</button>
  </form>

  <p class="auth-oauth-note">
    Signed up with <strong>Google</strong> or <strong>GitHub</strong>? You don't have a password
    to reset &mdash; just <a href="/architect-zero/auth/sign-in">sign back in</a> via your provider.
  </p>

  <p class="auth-links">
    <a href="/architect-zero/auth/sign-in">Back to sign in</a>
  </p>
</AuthLayout>

<style is:global>
  .auth-oauth-note {
    margin: 18px 0 0;
    padding: 12px 14px;
    background: var(--bg-3);
    border: 1px solid var(--bg-4);
    border-radius: 8px;
    color: var(--subtle);
    font-size: 12px;
    line-height: 1.6;
  }
  .auth-oauth-note strong { color: var(--text); font-weight: 600; }
  .auth-oauth-note a { color: var(--electric); text-decoration: none; }
  .auth-oauth-note a:hover { text-decoration: underline; }
</style>

<script>
  import { supabase } from '../../../lib/supabase';

  const form = document.getElementById('forgot-form') as HTMLFormElement | null;
  const errEl = document.getElementById('auth-error');
  const infoEl = document.getElementById('auth-info');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errEl) errEl.textContent = '';
      if (infoEl) { infoEl.style.display = 'none'; infoEl.textContent = ''; }

      const data = new FormData(form);
      const email = String(data.get('email') || '').trim();

      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submit) { submit.disabled = true; submit.textContent = 'Sending...'; }

      const { error } = await supabase.auth.resetPasswordForEmail(email, {
        redirectTo: window.location.origin + '/architect-zero/auth/reset-password',
      });

      if (error) {
        if (errEl) errEl.textContent = error.message;
        if (submit) { submit.disabled = false; submit.textContent = 'Send reset link'; }
        return;
      }

      if (infoEl) {
        infoEl.style.display = 'block';
        infoEl.textContent = 'If an account exists for that email, a reset link is on its way.';
      }
      form.reset();
      if (submit) { submit.disabled = false; submit.textContent = 'Send reset link'; }
    });
  }
</script>
