---
import AuthLayout from '../../../layouts/AuthLayout.astro';
import OAuthButtons from '../../../components/auth/OAuthButtons.astro';
---

<AuthLayout title="Sign in — Architect Zero" description="Sign in to continue your CCA exam prep">
  <header class="auth-header">
    <h1>Welcome back</h1>
    <p>Pick up where you left off.</p>
  </header>

  <OAuthButtons label="Sign in" />

  <div class="auth-divider"><span>or with email</span></div>

  <form id="sign-in-form" novalidate>
    <label class="field">
      <span>Email</span>
      <input type="email" name="email" autocomplete="email" required placeholder="you@example.com" />
    </label>
    <label class="field">
      <span>Password</span>
      <input type="password" name="password" autocomplete="current-password" required minlength="8" placeholder="At least 8 characters" />
    </label>

    <p id="auth-error" class="auth-error" role="alert" aria-live="polite"></p>

    <button type="submit" class="auth-submit">Sign in</button>
  </form>

  <p class="auth-links">
    <a href="/architect-zero/auth/forgot-password">Forgot password?</a>
    <span aria-hidden="true">·</span>
    <a href="/architect-zero/auth/sign-up">Create an account</a>
  </p>
</AuthLayout>

<script>
  import { supabase } from '../../../lib/supabase';
  import { consumeIntendedUrl, rememberIntendedUrl } from '../../../lib/auth';

  const params = new URL(window.location.href).searchParams;
  const next = params.get('next');
  if (next && next.startsWith('/architect-zero/') && !next.includes('/auth/')) {
    rememberIntendedUrl(next);
  }

  const form = document.getElementById('sign-in-form') as HTMLFormElement | null;
  const errEl = document.getElementById('auth-error');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errEl) errEl.textContent = '';
      const data = new FormData(form);
      const email = String(data.get('email') || '').trim();
      const password = String(data.get('password') || '');

      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submit) { submit.disabled = true; submit.textContent = 'Signing in...'; }

      const { error } = await supabase.auth.signInWithPassword({ email, password });

      if (error) {
        if (errEl) errEl.textContent = error.message;
        if (submit) { submit.disabled = false; submit.textContent = 'Sign in'; }
        return;
      }
      window.location.replace(consumeIntendedUrl());
    });
  }
</script>

<style is:global>
  .auth-header {
    margin-bottom: 24px;
    text-align: center;
  }
  .auth-header h1 {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--white);
    margin: 0 0 6px;
  }
  .auth-header p {
    margin: 0;
    color: var(--subtle);
    font-size: 14px;
  }
  .auth-divider {
    margin: 20px 0;
    text-align: center;
    position: relative;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: calc(50% - 80px);
    height: 1px;
    background: var(--bg-4);
  }
  .auth-divider::before { left: 0; }
  .auth-divider::after { right: 0; }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 14px;
  }
  .field > span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .field input {
    padding: 11px 14px;
    background: var(--bg-3);
    border: 1px solid var(--bg-4);
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    font-family: inherit;
    transition: border-color 150ms ease, background 150ms ease;
  }
  .field input:focus {
    outline: none;
    border-color: var(--brand-primary);
    background: var(--bg-2);
  }

  .auth-error {
    min-height: 18px;
    margin: 4px 0 12px;
    color: var(--signal);
    font-size: 13px;
    line-height: 1.4;
  }

  .auth-submit {
    width: 100%;
    padding: 12px 16px;
    background: var(--brand-gradient);
    border: 0;
    border-radius: 8px;
    color: var(--white);
    font-family: inherit;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: filter 150ms ease, transform 150ms var(--ease-out);
  }
  .auth-submit:hover:not(:disabled) {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .auth-submit:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  .auth-links {
    margin: 20px 0 0;
    text-align: center;
    font-size: 13px;
    color: var(--subtle);
  }
  .auth-links a {
    color: var(--electric);
    text-decoration: none;
  }
  .auth-links a:hover { text-decoration: underline; }
  .auth-links span { margin: 0 8px; color: var(--muted); }

  .auth-info {
    margin: 0;
    padding: 14px 16px;
    background: var(--electric-dim);
    border: 1px solid var(--electric-mid);
    border-radius: 8px;
    color: var(--text);
    font-size: 13px;
    line-height: 1.55;
  }
</style>
