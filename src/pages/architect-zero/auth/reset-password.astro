---
import AuthLayout from '../../../layouts/AuthLayout.astro';
---

<AuthLayout title="Set new password — Architect Zero" description="Choose a new password" showSignedInRedirect={false}>
  <header class="auth-header">
    <h1>Set a new password</h1>
    <p>Choose something at least 8 characters long.</p>
  </header>

  <form id="reset-form" novalidate>
    <label class="field">
      <span>New password</span>
      <input type="password" name="password" autocomplete="new-password" required minlength="8" />
    </label>
    <label class="field">
      <span>Confirm new password</span>
      <input type="password" name="confirm" autocomplete="new-password" required minlength="8" />
    </label>

    <p id="auth-error" class="auth-error" role="alert" aria-live="polite"></p>
    <p id="auth-info" class="auth-info" style="display:none"></p>

    <button type="submit" class="auth-submit">Update password</button>
  </form>

  <p class="auth-links">
    <a href="/architect-zero/auth/sign-in">Back to sign in</a>
  </p>
</AuthLayout>

<script>
  import { supabase } from '../../../lib/supabase';

  // Supabase puts the recovery token in the URL fragment.
  // detectSessionInUrl on the client handles the session creation automatically.

  const form = document.getElementById('reset-form') as HTMLFormElement | null;
  const errEl = document.getElementById('auth-error');
  const infoEl = document.getElementById('auth-info');

  // Verify we have a recovery session (Supabase sets one when the user lands via the email link).
  const { data: sessionData } = await supabase.auth.getSession();
  if (!sessionData.session && errEl) {
    errEl.textContent = 'Reset link is invalid or expired. Request a new one.';
    if (form) {
      form.querySelector('button[type="submit"]')?.setAttribute('disabled', 'true');
    }
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errEl) errEl.textContent = '';
      if (infoEl) { infoEl.style.display = 'none'; infoEl.textContent = ''; }

      const data = new FormData(form);
      const password = String(data.get('password') || '');
      const confirm = String(data.get('confirm') || '');

      if (password !== confirm) {
        if (errEl) errEl.textContent = 'Passwords do not match.';
        return;
      }

      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submit) { submit.disabled = true; submit.textContent = 'Updating...'; }

      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        if (errEl) errEl.textContent = error.message;
        if (submit) { submit.disabled = false; submit.textContent = 'Update password'; }
        return;
      }

      if (infoEl) {
        infoEl.style.display = 'block';
        infoEl.textContent = 'Password updated. Redirecting to your dashboard...';
      }
      setTimeout(() => { window.location.replace('/architect-zero/'); }, 1200);
    });
  }
</script>
