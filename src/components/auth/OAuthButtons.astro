---
interface Props {
  label?: string;
}
const { label = 'Continue' } = Astro.props;
---

<div class="oauth-buttons">
  <button type="button" class="oauth-btn" data-provider="google" aria-label="Sign in with Google">
    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    <span>{label} with Google</span>
  </button>

  <button type="button" class="oauth-btn" data-provider="github" aria-label="Sign in with GitHub">
    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18a10.95 10.95 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.69.41.36.78 1.05.78 2.12v3.15c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
    </svg>
    <span>{label} with GitHub</span>
  </button>
</div>

<script>
  import { supabase } from '../../lib/supabase';
  import { rememberIntendedUrl, AUTH_ROUTES } from '../../lib/auth';

  document.querySelectorAll<HTMLButtonElement>('.oauth-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const provider = btn.dataset.provider as 'google' | 'github' | undefined;
      if (!provider) return;

      const intended = sessionStorage.getItem('az_redirect_after_auth');
      if (!intended) {
        const fromQuery = new URL(window.location.href).searchParams.get('next');
        if (fromQuery && fromQuery.startsWith('/architect-zero/')) {
          rememberIntendedUrl(fromQuery);
        }
      }

      btn.disabled = true;
      btn.dataset.loading = 'true';
      const { error } = await supabase.auth.signInWithOAuth({
        provider,
        options: {
          redirectTo: window.location.origin + AUTH_ROUTES.callback,
        },
      });

      if (error) {
        btn.disabled = false;
        delete btn.dataset.loading;
        const err = document.getElementById('auth-error');
        if (err) err.textContent = error.message;
      }
    });
  });
</script>

<style>
  .oauth-buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 11px 16px;
    background: var(--bg-3);
    border: 1px solid var(--bg-4);
    border-radius: 8px;
    color: var(--text);
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 150ms var(--ease-out);
  }
  .oauth-btn:hover:not(:disabled) {
    border-color: var(--brand-primary-mid);
    background: var(--bg-2);
    transform: translateY(-1px);
  }
  .oauth-btn:disabled {
    opacity: 0.55;
    cursor: progress;
  }
  .oauth-btn[data-provider='github'] {
    color: var(--text);
  }
</style>
