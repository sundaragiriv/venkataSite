---
// Compact row of social channel icons. Use in footers / contact areas.
// Icons are inline SVGs (no external library) and use currentColor so they
// inherit the surrounding text color.

interface Props {
  size?: number;
  variant?: 'muted' | 'bright';   // muted = subtle/muted color, bright = white
}

const { size = 18, variant = 'muted' } = Astro.props;

const channels = [
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/sundaragiri',
    svg: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    label: 'YouTube',
    href: 'https://youtube.com/@architectZero-LMS',
    svg: `<path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>`,
  },
  {
    label: 'X (Twitter)',
    href: 'https://x.com/architectzero',
    svg: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zM17.083 19.77h1.833L7.084 4.126H5.117L17.083 19.77z"/>`,
  },
];
---

<ul class:list={['social-row', `social-row-${variant}`]} aria-label="Social channels">
  {channels.map((c) => (
    <li>
      <a
        href={c.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={c.label}
        title={c.label}
      >
        <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={c.svg} />
      </a>
    </li>
  ))}
</ul>

<style>
  .social-row {
    display: flex;
    align-items: center;
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social-row a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms ease, background 150ms ease, transform 150ms var(--ease-out);
  }
  .social-row a:hover {
    color: var(--brand);
    background: var(--bg-3);
    transform: translateY(-1px);
  }
  .social-row-bright a { color: var(--subtle); }
  .social-row-bright a:hover { color: var(--white); }
</style>
