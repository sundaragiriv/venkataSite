---
interface Props {
  variant?: 'brand' | 'az' | 'lesson';
  bubbles?: boolean;
  domainColor?: string;
}

const { variant = 'brand', bubbles = false, domainColor = '#00e5ff' } = Astro.props;
const rand = (min: number, max: number) => Math.random() * (max - min) + min;
const bubbleConfigs = bubbles
  ? Array.from({ length: 32 }, () => ({
      size: Math.round(rand(8, 72)),
      x: Math.round(rand(0, 100)),
      duration: Math.round(rand(18, 38)),
      delay: -Math.round(rand(0, 38)),
      drift: Math.round(rand(-40, 40)),
      opacity: (rand(8, 24) / 100).toFixed(2),
    }))
  : [];
---

<div
  class:list={['brand-ambient', `brand-ambient-${variant}`, { 'has-bubbles': bubbles }]}
  style={`--domain-color:${domainColor};`}
  aria-hidden="true"
>
  <div class="brand-grid-bg"></div>
  <div class="brand-orb brand-orb-1"></div>
  <div class="brand-orb brand-orb-2"></div>
  <div class="brand-orb brand-orb-3"></div>
  {bubbleConfigs.map((bubble) => (
    <div
      class="bubble"
      style={`--size:${bubble.size}px;--x:${bubble.x}%;--duration:${bubble.duration}s;--delay:${bubble.delay}s;--drift:${bubble.drift}px;--opacity:${bubble.opacity};`}
    />
  ))}
  <div class="brand-noise"></div>
</div>

<style is:global>
  .brand-ambient {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .brand-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 255, 65, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 65, 0.08) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, black, transparent 82%);
    opacity: 0.42;
  }

  .brand-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.9;
    animation: brandOrbFloat 18s var(--ease-soft) infinite alternate;
  }

  .brand-orb-1 {
    width: 680px;
    height: 680px;
    top: -260px;
    right: -160px;
    background: conic-gradient(from 120deg, rgba(0, 255, 65, 0.18), rgba(138, 255, 193, 0.04), rgba(255, 79, 126, 0.08), rgba(0, 255, 65, 0.18));
  }

  .brand-orb-2 {
    width: 460px;
    height: 460px;
    bottom: -170px;
    left: -130px;
    background: conic-gradient(from 250deg, rgba(0, 255, 65, 0.14), rgba(255, 209, 102, 0.07), transparent, rgba(0, 255, 65, 0.14));
    animation-delay: -7s;
  }

  .brand-orb-3 {
    width: 360px;
    height: 360px;
    top: 36%;
    left: 54%;
    background: radial-gradient(circle, rgba(0, 255, 65, 0.08), transparent 68%);
    animation-delay: -12s;
  }

  .brand-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.055'/%3E%3C/svg%3E");
    opacity: 0.5;
  }

  .bubble {
    position: absolute;
    bottom: -10vh;
    left: var(--x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, currentColor 0%, transparent 70%);
    color: var(--brand);
    opacity: var(--opacity);
    filter: blur(0.5px);
    animation: bubbleRise var(--duration) linear infinite;
    animation-delay: var(--delay);
    will-change: transform;
    pointer-events: none;
  }

  body.brand-page .bubble {
    color: var(--brand);
  }

  body:not(.brand-page) .bubble {
    color: var(--electric);
  }

  .brand-ambient-az .brand-grid-bg {
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.08) 1px, transparent 1px);
    opacity: 0.34;
  }

  .brand-ambient-az .brand-orb {
    opacity: 0;
    animation: none;
  }

  .brand-ambient-az .brand-orb-1 {
    opacity: 1;
    top: -260px;
    right: -220px;
    width: 620px;
    height: 620px;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.04), transparent 68%);
    filter: blur(0);
  }

  .brand-ambient-lesson .brand-grid-bg {
    background-image:
      linear-gradient(color-mix(in srgb, var(--domain-color) 12%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--domain-color) 12%, transparent) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.22;
  }

  .brand-ambient-lesson .brand-orb {
    opacity: 0;
    animation: none;
  }

  .brand-ambient-lesson .brand-orb-1 {
    opacity: 1;
    top: -220px;
    right: -180px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle, color-mix(in srgb, var(--domain-color) 10%, transparent), transparent 70%);
    filter: blur(0);
  }

  @keyframes bubbleRise {
    0% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(var(--drift), -60vh, 0) scale(1.05); }
    100% { transform: translate3d(0, -120vh, 0) scale(0.9); }
  }

  @keyframes brandOrbFloat {
    from { transform: translate3d(0, 0, 0) rotate(0deg); }
    to { transform: translate3d(34px, -24px, 0) rotate(18deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-ambient .brand-orb {
      animation: none;
    }

    .bubble {
      animation: none;
      opacity: 0;
    }
  }
</style>
