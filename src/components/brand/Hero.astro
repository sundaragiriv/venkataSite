---
import AmbientField from './AmbientField.astro';
---

<nav id="navbar" class="brand-nav">
  <a href="#" class="nav-logo">
    <div class="nav-logo-dot"></div>
    <span>VENKATA.INFO</span>
  </a>
  <div id="brandNavLinks" class="nav-links">
    <a href="#story" class="nav-link">Story</a>
    <a href="#building" class="nav-link">Building</a>
    <a href="#series" class="nav-link">Architect Zero</a>
    <a href="#app" class="nav-link">Study App</a>
    <a href="#contact" class="nav-cta">Contact</a>
  </div>
  <button id="navMenuButton" class="nav-hamburger" type="button" aria-label="Open navigation" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div class="hero">
  <AmbientField variant="brand" bubbles />
  <div class="hero-content">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow">venkata.info</div>
        <div class="hero-name">
          VENKATA<br />
          <span class="hero-name-electric">SUNDARAGIRI</span>
        </div>
        <div class="hero-title">Solution Architect - AI Educator</div>
        <div class="hero-statement">
          <strong>SAP is my bread and butter.</strong><br />
          <em>AI is my future.</em><br /><br />
          23 years in enterprise architecture, now building at the AI frontier.
          I design production systems, teach what I learn, and turn complex architecture into usable tools.
        </div>
        <div class="hero-chips">
          <span class="chip chip-electric">23 Years Enterprise</span>
          <span class="chip chip-gold">SAP S/4HANA</span>
          <span class="chip chip-signal">CCA Candidate</span>
          <span class="chip chip-muted">Architect Zero</span>
        </div>
        <div class="hero-actions">
          <a href="/architect-zero/" class="btn-primary">Watch Architect Zero</a>
          <a href="#story" class="btn-secondary">Read The Story</a>
        </div>
      </div>

      <div class="hero-avatar">
        <div class="avatar-frame">
          <img
            src="/Avatar.jpeg"
            alt="Venkata Sundaragiri — creator of Architect Zero"
            class="avatar-photo"
            loading="eager"
            decoding="async"
          />
          <div class="avatar-tint" aria-hidden="true"></div>
          <div class="avatar-scanlines" aria-hidden="true"></div>
          <div class="avatar-noise" aria-hidden="true"></div>
          <div class="avatar-vignette" aria-hidden="true"></div>
          <div class="avatar-scanline"></div>
          <div class="avatar-corner avatar-corner-tl"></div>
          <div class="avatar-corner avatar-corner-tr"></div>
          <div class="avatar-corner avatar-corner-bl"></div>
          <div class="avatar-corner avatar-corner-br"></div>
          <div class="avatar-rec" aria-hidden="true">
            <span class="avatar-rec-dot"></span>
            <span class="avatar-rec-label">REC</span>
          </div>
          <div class="avatar-feed" aria-hidden="true">CH-01 / VS-04 / 2026</div>
          <div class="avatar-caption">
            <div class="avatar-caption-name">VENKATA SUNDARAGIRI</div>
            <div class="avatar-caption-role">Architect Zero · Creator</div>
          </div>
          <div class="avatar-status">
            <div class="status-dot"></div>
            <div class="status-text">SIGNAL // CCA-01 LIVE</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <div class="scroll-label">Scroll</div>
  </div>
</div>
