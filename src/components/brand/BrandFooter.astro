<footer class="brand-footer">
  <div class="footer-logo">
    <a href="/">VENKATA.INFO</a>
    <span class="footer-logo-sep">||</span>
    <a href="/architect-zero/">ARCHITECT <span class="footer-logo-accent">ZERO</span></a>
  </div>
  <nav class="footer-links" aria-label="Footer">
    <a href="/privacy/">Privacy</a>
    <a href="/terms/">Terms</a>
    <a href="https://youtube.com/@architectzero" target="_blank" rel="noopener noreferrer">YouTube</a>
    <a href="mailto:sundaragiriv@gmail.com">Contact</a>
  </nav>
  <div class="footer-copy">© 2026 Venkata Sundaragiri</div>
</footer>

<style>
  .brand-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 32px;
    padding: 28px 48px;
    border-top: 1px solid var(--bg-4);
    background: var(--bg-0);
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 15px;
    letter-spacing: 3px;
    color: var(--white);
  }
  .footer-logo a {
    color: var(--white);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-logo a:hover { color: var(--brand); }
  .footer-logo-sep {
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
  }
  .footer-logo-accent { color: var(--electric); }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .footer-links a {
    color: var(--subtle);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-links a:hover { color: var(--brand); }

  .footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.2px;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .brand-footer { padding: 24px 20px; flex-direction: column; align-items: flex-start; gap: 14px; }
  }
</style>
