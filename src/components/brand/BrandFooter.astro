---
import SocialIcons from '../SocialIcons.astro';
---

<footer class="brand-footer">
  <div class="footer-top">
    <div class="footer-newsletter">
      <div class="footer-newsletter-eyebrow">Stay in the loop</div>
      <p class="footer-newsletter-body">
        New series drops, video episodes, and major updates &mdash; one email when there's
        something worth saying. No spam, easy unsubscribe.
      </p>
      <form id="newsletter-form" class="newsletter-form" novalidate>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          aria-label="Email address"
        />
        <button type="submit" class="newsletter-submit">Subscribe &rarr;</button>
        <p id="newsletter-msg" class="newsletter-msg" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-logo">
      <a href="/">VENKATA.INFO</a>
      <span class="footer-logo-sep">||</span>
      <a href="/architect-zero/">ARCHITECT <span class="footer-logo-accent">ZERO</span></a>
    </div>
    <nav class="footer-links" aria-label="Footer">
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="/contact/">Contact</a>
    </nav>
    <div class="footer-social"><SocialIcons size={18} variant="muted" /></div>
    <div class="footer-copy">© 2026 Venkata Sundaragiri</div>
  </div>
</footer>

<script>
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-msg');

  function show(text: string, ok: boolean) {
    if (!msg) return;
    msg.textContent = text;
    msg.dataset.state = ok ? 'ok' : 'err';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (msg) { msg.textContent = ''; delete msg.dataset.state; }
    const data = new FormData(form);
    const email = String(data.get('email') || '').trim().toLowerCase();
    if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
      show('Enter a valid email address.', false);
      return;
    }

    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submit) { submit.disabled = true; submit.textContent = 'Subscribing...'; }

    const { data: session } = await supabase.auth.getSession();
    const userId = session.session?.user.id ?? null;

    const { error } = await supabase.from('newsletter_subscribers').insert({
      email,
      source: 'footer',
      user_id: userId,
    });

    if (error) {
      // 23505 = unique_violation. Treat existing subscription as success-ish.
      if (error.code === '23505') {
        show("You're already subscribed. Thanks for being here.", true);
        form.reset();
      } else {
        show('Could not subscribe right now. Try again in a minute.', false);
      }
    } else {
      show("Subscribed. We'll be in touch when there's news.", true);
      form.reset();
    }

    if (submit) { submit.disabled = false; submit.textContent = 'Subscribe →'; }
  });
</script>

<style>
  .brand-footer {
    border-top: 1px solid var(--bg-4);
    background: var(--bg-0);
    padding: 0;
  }

  .footer-top {
    padding: 56px 48px 40px;
    border-bottom: 1px solid var(--bg-4);
    display: flex;
    justify-content: center;
  }

  .footer-newsletter {
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .footer-newsletter-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 8px;
  }

  .footer-newsletter-body {
    margin: 0 0 18px;
    font-size: 14px;
    line-height: 1.65;
    color: var(--subtle);
  }

  .newsletter-form {
    display: flex;
    gap: 8px;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    flex-wrap: wrap;
  }
  .newsletter-form input[type='email'] {
    flex: 1;
    min-width: 220px;
    padding: 11px 14px;
    background: var(--bg-2);
    border: 1px solid var(--bg-4);
    border-radius: 8px;
    color: var(--text);
    font-family: inherit;
    font-size: 14px;
    transition: border-color 150ms ease, background 150ms ease;
  }
  .newsletter-form input[type='email']:focus {
    outline: none;
    border-color: var(--brand);
    background: var(--bg-3);
  }
  .newsletter-submit {
    padding: 11px 20px;
    background: var(--brand-gradient);
    border: 0;
    border-radius: 8px;
    color: var(--white);
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: filter 150ms ease, transform 150ms var(--ease-out);
  }
  .newsletter-submit:hover:not(:disabled) {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .newsletter-submit:disabled {
    opacity: 0.6;
    cursor: progress;
  }
  .newsletter-msg {
    width: 100%;
    margin: 6px 0 0;
    min-height: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--muted);
    text-align: center;
  }
  .newsletter-msg[data-state='ok']  { color: var(--mint, #10b981); }
  .newsletter-msg[data-state='err'] { color: var(--signal); }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 32px;
    padding: 28px 48px;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 15px;
    letter-spacing: 3px;
    color: var(--white);
  }
  .footer-logo a {
    color: var(--white);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-logo a:hover { color: var(--brand); }
  .footer-logo-sep {
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
  }
  .footer-logo-accent { color: var(--electric); }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .footer-links a {
    color: var(--subtle);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-links a:hover { color: var(--brand); }

  .footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.2px;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .footer-top { padding: 40px 20px 32px; }
    .footer-bottom { padding: 24px 20px; flex-direction: column; align-items: flex-start; gap: 14px; }
    .newsletter-form { flex-direction: column; }
    .newsletter-form input[type='email'],
    .newsletter-submit { width: 100%; }
  }
</style>
