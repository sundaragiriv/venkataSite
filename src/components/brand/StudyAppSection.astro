---
---

<section id="app" class="brand-section">
  <div class="section-header reveal">
    <div class="section-eyebrow">Free Study Tool</div>
    <div class="section-title">THE CCA<br /><span>STUDY APP</span></div>
  </div>

  <div class="app-feature reveal">
    <div>
      <div class="hero-statement" style="font-size:15px;max-width:480px;margin-bottom:28px;">
        The CCA Study App is available now as the Architect Zero PWA.
        It includes domain lessons, practice questions, flashcards, progress tracking,
        mobile install support, and an XP loop for repeated study.
      </div>
      <div class="hero-chips" style="margin-bottom:28px;">
        <span class="chip chip-electric">128 Study Pages</span>
        <span class="chip chip-signal">108 Questions</span>
        <span class="chip chip-gold">90 Flashcards</span>
        <span class="chip chip-muted">Progress</span>
        <span class="chip chip-muted">XP System</span>
        <span class="chip chip-muted">Free</span>
      </div>
      <a href="/architect-zero/" class="btn-primary" style="width:fit-content;margin-bottom:12px;">
        Open Study App
      </a>
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:1px;">
        Open on mobile, then add Architect Zero to your home screen.
      </div>
    </div>

    <div class="app-mockup">
      <div class="app-mockup-header">
        <div class="app-mockup-title">CCA STUDY</div>
        <div class="app-mockup-badge">V1 LIVE</div>
      </div>
      <div class="app-domain" style="border-left-color:#00ff41">
        <div>
          <div class="app-domain-name">D0 - AI & Claude Foundations</div>
          <div class="app-pbar"><div class="app-pbar-fill" style="width:100%;background:#00ff41"></div></div>
        </div>
        <div class="app-domain-pct" style="color:#00ff41">100%</div>
      </div>
      <div class="app-domain" style="border-left-color:#8affc1">
        <div>
          <div class="app-domain-name">D1 - Agentic Architecture - 27%</div>
          <div class="app-pbar"><div class="app-pbar-fill" style="width:60%;background:#8affc1"></div></div>
        </div>
        <div class="app-domain-pct" style="color:#8affc1">60%</div>
      </div>
      <div class="app-domain" style="border-left-color:#ffd166">
        <div>
          <div class="app-domain-name">D2 - Tool Design & MCP - 18%</div>
          <div class="app-pbar"><div class="app-pbar-fill" style="width:40%;background:#ffd166"></div></div>
        </div>
        <div class="app-domain-pct" style="color:#ffd166">40%</div>
      </div>
      <div class="app-domain" style="border-left-color:#ff4f7e">
        <div>
          <div class="app-domain-name">D3 - Claude Code - 20%</div>
          <div class="app-pbar"><div class="app-pbar-fill" style="width:20%;background:#ff4f7e"></div></div>
        </div>
        <div class="app-domain-pct" style="color:#ff4f7e">20%</div>
      </div>
      <div class="app-domain" style="border-left-color:#a5b7ad">
        <div>
          <div class="app-domain-name">D4 - Prompt Engineering - 20%</div>
          <div class="app-pbar"><div class="app-pbar-fill" style="width:0%;background:#a5b7ad"></div></div>
        </div>
        <div class="app-domain-pct" style="color:#a5b7ad">0%</div>
      </div>
      <div class="app-domain" style="border-left-color:#688073">
        <div>
          <div class="app-domain-name">D5 - Context & Reliability - 15%</div>
          <div class="app-pbar"><div class="app-pbar-fill" style="width:0%;background:#688073"></div></div>
        </div>
        <div class="app-domain-pct" style="color:#688073">0%</div>
      </div>
    </div>
  </div>
</section>
