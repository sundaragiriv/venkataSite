---
---

<section id="install" class="brand-section">
  <div class="section-header reveal">
    <div class="section-eyebrow">Install on your phone</div>
    <div class="section-title">ARCHITECT ZERO<br /><span>ON YOUR HOME SCREEN</span></div>
  </div>

  <div class="install-grid reveal">
    <div class="install-card">
      <div class="install-card-platform">iOS · Safari</div>
      <h3>Install on iPhone or iPad</h3>
      <ol class="install-steps">
        <li>Open <strong>venkata.info/architect-zero/</strong> in Safari</li>
        <li>Tap the <strong>Share</strong> button (square with arrow up)</li>
        <li>Scroll down and tap <strong>Add to Home Screen</strong></li>
        <li>Tap <strong>Add</strong> in the top right</li>
      </ol>
      <p class="install-note">Works offline once installed. Sync stays live when online.</p>
    </div>

    <div class="install-card">
      <div class="install-card-platform">Android · Chrome</div>
      <h3>Install on Android</h3>
      <ol class="install-steps">
        <li>Open <strong>venkata.info/architect-zero/</strong> in Chrome</li>
        <li>Tap the menu (<strong>⋮</strong>) in the top right</li>
        <li>Tap <strong>Install app</strong> (or <strong>Add to Home Screen</strong>)</li>
        <li>Confirm <strong>Install</strong></li>
      </ol>
      <p class="install-note">Native-feeling app icon. Push notifications when enabled.</p>
    </div>
  </div>

  <p class="install-fine reveal">
    Architect Zero is a Progressive Web App &mdash; no App Store / Play Store download
    required. Native iOS &amp; Android wrappers may follow if there's demand.
  </p>
</section>

<style>
  .install-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) {
    .install-grid { grid-template-columns: 1fr; }
  }

  .install-card {
    background: var(--bg-2);
    border: 1px solid var(--bg-4);
    border-radius: 14px;
    padding: 28px 28px 24px;
    position: relative;
    overflow: hidden;
    transition: transform 250ms var(--ease-snap), border-color 250ms ease;
  }
  .install-card:hover {
    transform: translateY(-2px);
    border-color: var(--brand-primary-mid);
  }
  .install-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: var(--brand-gradient);
    opacity: 0;
    transition: opacity 250ms ease;
  }
  .install-card:hover::before { opacity: 1; }

  .install-card-platform {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2.5px;
    color: var(--brand);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .install-card h3 {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--white);
    margin: 0 0 18px;
  }

  .install-steps {
    list-style: none;
    counter-reset: install-step;
    margin: 0 0 18px;
    padding: 0;
    font-size: 14px;
    color: var(--subtle);
    line-height: 1.6;
  }
  .install-steps li {
    counter-increment: install-step;
    padding: 8px 0 8px 36px;
    position: relative;
    border-bottom: 1px dashed var(--bg-4);
  }
  .install-steps li:last-child { border-bottom: 0; }
  .install-steps li::before {
    content: counter(install-step);
    position: absolute;
    left: 0;
    top: 8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--brand-primary-dim);
    border: 1px solid var(--brand-primary-mid);
    color: var(--brand);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .install-steps strong { color: var(--white); font-weight: 600; }

  .install-note {
    margin: 0;
    padding: 12px 14px;
    background: rgba(6, 182, 212, 0.06);
    border: 1px solid var(--electric-mid);
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--electric);
    letter-spacing: 0.5px;
  }

  .install-fine {
    font-size: 13px;
    color: var(--muted);
    text-align: center;
    margin: 0;
    line-height: 1.7;
  }
</style>
