---
interface Props {
  title?: string;
  showBack?: boolean;
  backHref?: string;
  rightSlot?: string;
}

const {
  title,
  showBack = false,
  backHref = '/',
  rightSlot,
} = Astro.props;
---

<header class="az-header px-4 pt-3 pb-2 safe-top">
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-2">
      {showBack && (
        <a href={backHref} class="text-az-muted text-xl leading-none mr-1">←</a>
      )}
      <div>
        {title ? (
          <div class="text-[15px] font-black text-white">{title}</div>
        ) : (
          <div class="text-[15px] font-display tracking-widest text-white">
            ARCHITECT <span class="text-electric">ZERO</span>
          </div>
        )}
        <div class="text-[10px] text-az-muted font-mono" id="header-sub">
          Loading...
        </div>
      </div>
    </div>
    <div id="header-level" class="text-[9px] font-black tracking-widest uppercase px-2 py-0.5 rounded-full bg-az-indigo/10 text-az-indigo border border-az-indigo/20">
      Lv.1
    </div>
  </div>

  <!-- XP BAR -->
  <div class="xp-bar">
    <div class="xp-fill" id="global-xp-fill" style="width:0%"></div>
  </div>
  <div class="flex justify-between mt-1">
    <span class="text-[9px] text-az-muted font-mono" id="xp-left">Level 1</span>
    <span class="text-[9px] text-az-muted font-mono" id="xp-right">200 XP → Explorer</span>
  </div>
</header>

<script>
  function updateHeader() {
    try {
      const xp = Number(localStorage.getItem('az_xp') || '0');
      const streak = Number(localStorage.getItem('az_streak') || '0');
      const levels = [
        {level:1,title:'Curious',   xpNeeded:0,   color:'#94a3b8'},
        {level:2,title:'Explorer',  xpNeeded:200, color:'#60a5fa'},
        {level:3,title:'Builder',   xpNeeded:500, color:'#34d399'},
        {level:4,title:'Designer',  xpNeeded:1000,color:'#fbbf24'},
        {level:5,title:'Architect', xpNeeded:1800,color:'#f97316'},
        {level:6,title:'Master',    xpNeeded:2800,color:'#e879f9'},
        {level:7,title:'CCA Ready', xpNeeded:4000,color:'#00e5ff'},
      ];
      const cur = levels.reduce((acc, l) => xp >= l.xpNeeded ? l : acc, levels[0]);
      const next = levels[cur.level] || null;
      const pct = next
        ? Math.round(((xp - cur.xpNeeded) / (next.xpNeeded - cur.xpNeeded)) * 100)
        : 100;

      const sub = document.getElementById('header-sub');
      const lvl = document.getElementById('header-level');
      const fill = document.getElementById('global-xp-fill');
      const left = document.getElementById('xp-left');
      const right = document.getElementById('xp-right');

      if (sub) sub.textContent = `${cur.title} · ${xp} XP · 🔥 ${streak}d`;
      if (lvl) { lvl.textContent = `Lv.${cur.level}`; lvl.style.color = cur.color; }
      if (fill) {
        fill.style.width = pct + '%';
        fill.style.background = `linear-gradient(90deg, ${cur.color}, #00e5ff)`;
      }
      if (left) left.textContent = `Level ${cur.level}`;
      if (right) right.textContent = next
        ? `${next.xpNeeded - xp} XP → ${next.title}`
        : 'MAX LEVEL';
    } catch(e) {}
  }
  updateHeader();
</script>
