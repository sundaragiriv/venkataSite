---
import { ViewTransitions } from 'astro:transitions';
import ImportPrompt from '../components/auth/ImportPrompt.astro';
import AzFooter from '../components/AzFooter.astro';
import SeoMeta from '../components/SeoMeta.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[] | null;
}

const {
  title = 'Architect Zero — CCA Foundations',
  description = 'Architect Zero — an LMS for technical certifications. First series: Claude Certified Architect (CCA) exam prep. 114 lessons, 108 quiz questions, 90 flashcards, free.',
  ogImage,
  jsonLd = null,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/architect-zero/',           icon: '◈',  emoji: '🏠', label: 'Dashboard'  },
  { href: '/architect-zero/learn',      icon: '▤',  emoji: '📚', label: 'Learn'       },
  { href: '/architect-zero/academy',    icon: '✦',  emoji: '🎓', label: 'Academy'     },
  { href: '/architect-zero/quiz',       icon: '◉',  emoji: '🎯', label: 'Quiz'        },
  { href: '/architect-zero/flashcards', icon: '◫',  emoji: '🃏', label: 'Flashcards'  },
  { href: '/architect-zero/progress',   icon: '◑',  emoji: '📈', label: 'Progress'    },
];

function isActive(href: string) {
  if (href === '/architect-zero/') return currentPath === '/architect-zero/';
  return currentPath.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="Architect Zero"/>
  <meta name="theme-color" content="#04040a"/>
  <link rel="manifest" href="/manifest.webmanifest"/>
  <ViewTransitions />
  <SeoMeta title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
  <style is:inline>
    body.az-gating #app,
    body.az-gating #level-up-overlay { visibility: hidden; }
    .az-gate-overlay {
      position: fixed;
      inset: 0;
      background: #04040a;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #6a6a9a;
    }
    body:not(.az-gating) .az-gate-overlay { display: none; }
  </style>
  <script is:inline>
    // Synchronous session check on first paint. Authed users skip the
    // "Loading..." overlay; unauthed users stay gated until the async
    // module script redirects them to sign-in.
    (function () {
      try {
        var path = window.location.pathname;
        if (!path.endsWith('/')) path += '/';
        var bypass = path.indexOf('/architect-zero/auth/') !== -1
                  || path.indexOf('/architect-zero/_dev/') !== -1;
        var hasSession = false;
        for (var i = 0; i < localStorage.length; i++) {
          var k = localStorage.key(i);
          if (k && /^sb-.*-auth-token$/.test(k)) {
            var v = localStorage.getItem(k);
            if (v && v.indexOf('access_token') !== -1) { hasSession = true; break; }
          }
        }
        if (bypass || hasSession) {
          if (document.body) document.body.classList.remove('az-gating');
          else document.addEventListener('DOMContentLoaded', function () { document.body.classList.remove('az-gating'); });
        }
      } catch (e) { /* localStorage blocked — fall through to async gate */ }
    })();
  </script>
</head>
<body class="az-gating">

<div class="az-gate-overlay" aria-hidden="true">Loading...</div>

<div id="app">

  <!-- ══════════════════════════════════
       SIDEBAR — desktop only
       ══════════════════════════════════ -->
  <aside id="sidebar">

    <!-- Umbrella back-link -->
    <a href="/" class="sidebar-umbrella" aria-label="Back to venkata.info">
      <span aria-hidden="true">&larr;</span>
      <span>venkata.info</span>
    </a>

    <!-- Logo -->
    <a href="/architect-zero/" class="sidebar-logo">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" class="sidebar-logo-mark">
        <polygon points="16,2 30,28 2,28" stroke="#06b6d4" stroke-width="2.5" fill="none" stroke-linejoin="round"/>
        <line x1="8" y1="20" x2="24" y2="20" stroke="#06b6d4" stroke-width="2"/>
        <circle cx="16" cy="16" r="3.5" stroke="white" stroke-width="1.5" fill="none"/>
        <circle cx="16" cy="16" r="1.5" fill="#06b6d4"/>
      </svg>
      <div class="sidebar-logo-text">
        <div class="sidebar-logo-name">ARCHITECT</div>
        <div class="sidebar-logo-zero">ZERO</div>
      </div>
    </a>

    <!-- Series pill -->
    <div class="sidebar-channel">
      <span class="sidebar-channel-dot"></span>
      CCA Series · 01
    </div>

    <!-- XP block -->
    <div class="sidebar-xp-block">
      <div class="sidebar-xp-top">
        <span id="sb-level" class="sidebar-level-label">Lv.1 Curious</span>
        <span id="sb-xp" class="sidebar-xp-val">0 XP</span>
      </div>
      <div class="sidebar-xp-track">
        <div class="sidebar-xp-fill" id="sb-xp-fill"></div>
      </div>
      <div id="sb-next" class="sidebar-xp-next">200 XP → Explorer</div>
    </div>

    <!-- Divider -->
    <div class="sidebar-divider"></div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
      {navItems.map(({ href, icon, label }) => (
        <a href={href} class={`sidebar-link ${isActive(href) ? 'is-active' : ''}`}>
          <span class="sidebar-link-icon">{icon}</span>
          <span class="sidebar-link-label">{label}</span>
        </a>
      ))}
    </nav>

    <!-- Footer -->
    <div class="sidebar-footer">
      <div class="sidebar-streak">
        <span>🔥</span>
        <span id="sb-streak">0 day streak</span>
      </div>
      <div class="sidebar-exam-tag">CCA Certified Architect</div>
      <div class="sidebar-account-row">
        <a href="/architect-zero/auth/account" class="sidebar-account" id="sb-account" aria-label="Account">
          <span class="sidebar-account-avatar" id="sb-avatar" aria-hidden="true">?</span>
          <span class="sidebar-account-name" id="sb-name">Account</span>
        </a>
        <button id="sb-signout" class="sidebar-signout" type="button" aria-label="Sign out" title="Sign out">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </button>
      </div>
    </div>

  </aside>

  <!-- ══════════════════════════════════
       MAIN AREA
       ══════════════════════════════════ -->
  <div id="main-wrap">

    <!-- TOP BAR — mobile only, hidden on desktop -->
    <header id="topbar">
      <div class="topbar-left">
        <a href="/" class="topbar-umbrella" aria-label="venkata.info">venkata.info</a>
        <a href="/architect-zero/" class="topbar-logo">
          ARCHITECT <span class="text-electric">ZERO</span>
        </a>
      </div>
      <div class="topbar-right">
        <span id="tb-level" class="topbar-level">Lv.1</span>
        <span id="tb-xp" class="topbar-xp">0 XP</span>
        <button id="mobile-menu-btn" onclick="toggleMobileMenu()" aria-label="Menu">☰</button>
      </div>
      <div class="topbar-xp-track">
        <div class="topbar-xp-fill" id="tb-xp-fill"></div>
      </div>
    </header>

    <!-- MAIN CONTENT -->
    <main id="content">
      <slot/>
    </main>

    <AzFooter />

  </div>

  <!-- ══════════════════════════════════
       BOTTOM NAV — mobile only
       ══════════════════════════════════ -->
  <nav id="bottom-nav">
    {navItems.slice(0, 6).map(({ href, emoji, label }) => (
      <a href={href} class={`bottom-link ${isActive(href) ? 'is-active' : ''}`}>
        <span class="bottom-icon">{emoji}</span>
        <span class="bottom-label">{label}</span>
      </a>
    ))}
  </nav>

  <!-- MOBILE MENU OVERLAY -->
  <div id="mobile-menu" style="display:none">
    <div class="mobile-menu-header">
      <span class="font-display text-white tracking-widest" style="font-size:18px">
        ARCHITECT <span class="text-electric">ZERO</span>
      </span>
      <button onclick="toggleMobileMenu()" style="background:none;border:none;color:#6a6a9a;font-size:20px;cursor:pointer">✕</button>
    </div>
    {navItems.map(({ href, emoji, label }) => (
      <a href={href} class={`mobile-menu-link ${isActive(href) ? 'is-active' : ''}`}
        onclick="toggleMobileMenu()">
        <span>{emoji}</span>
        <span>{label}</span>
      </a>
    ))}
  </div>

</div>

<!-- IMPORT PROMPT (shown after sign-in when local progress exists but cloud is empty) -->
<ImportPrompt />

<!-- LEVEL UP OVERLAY -->
<div id="level-up-overlay" style="display:none;position:fixed;inset:0;background:#04040a;z-index:200;display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:32px">
  <div style="font-size:72px;margin-bottom:16px">🎉</div>
  <div id="lu-label" style="font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;font-family:'JetBrains Mono',monospace">Level Up!</div>
  <div style="font-size:28px;font-weight:900;color:white;margin-bottom:4px">You're now a</div>
  <div id="lu-title" style="font-size:40px;font-weight:900;font-family:'Bebas Neue',Impact,sans-serif;letter-spacing:2px;margin-bottom:32px">Architect</div>
  <button onclick="document.getElementById('level-up-overlay').style.display='none'"
    style="background:#06b6d4;border:none;color:#04040a;padding:14px 48px;border-radius:8px;font-size:16px;font-weight:800;cursor:pointer">
    Keep Going →
  </button>
</div>

<script>
  // ── LEVELS ───────────────────────────────────────────
  const LEVELS = [
    {level:1,title:'Curious',   xpNeeded:0,   color:'#94a3b8'},
    {level:2,title:'Explorer',  xpNeeded:200, color:'#60a5fa'},
    {level:3,title:'Builder',   xpNeeded:500, color:'#34d399'},
    {level:4,title:'Designer',  xpNeeded:1000,color:'#fbbf24'},
    {level:5,title:'Architect', xpNeeded:1800,color:'#f97316'},
    {level:6,title:'Master',    xpNeeded:2800,color:'#e879f9'},
    {level:7,title:'CCA Ready', xpNeeded:4000,color:'#06b6d4'},
  ];
  function getLevel(xp) {
    return LEVELS.reduce((a,l) => xp >= l.xpNeeded ? l : a, LEVELS[0]);
  }
  function updateXP() {
    const xp  = Number(localStorage.getItem('az_xp') || '0');
    const str = Number(localStorage.getItem('az_streak') || '0');
    const cur = getLevel(xp);
    const next = LEVELS[cur.level] || null;
    const pct  = next ? Math.round(((xp-cur.xpNeeded)/(next.xpNeeded-cur.xpNeeded))*100) : 100;
    const grad = `linear-gradient(90deg, ${cur.color}, #06b6d4)`;
    // sidebar
    const s = (id, v) => { const e=document.getElementById(id); if(e) e.textContent=v; };
    const sc = (id, c) => { const e=document.getElementById(id); if(e) e.style.color=c; };
    const sw = (id, w, bg) => { const e=document.getElementById(id); if(e){e.style.width=w;if(bg)e.style.background=bg;} };
    s('sb-level', `Lv.${cur.level} ${cur.title}`); sc('sb-level', cur.color);
    s('sb-xp', `${xp} XP`);
    sw('sb-xp-fill', pct+'%', grad);
    s('sb-next', next ? `${next.xpNeeded-xp} XP → ${next.title}` : 'MAX LEVEL');
    s('sb-streak', `${str} day streak`);
    // topbar
    s('tb-level', `Lv.${cur.level}`); sc('tb-level', cur.color);
    s('tb-xp', `${xp} XP`);
    sw('tb-xp-fill', pct+'%', grad);
  }
  updateXP();
  window.addEventListener('xp-updated', updateXP);

  // ── MOBILE MENU ──────────────────────────────────────
  function toggleMobileMenu() {
    const m = document.getElementById('mobile-menu');
    if (!m) return;
    m.style.display = m.style.display === 'none' || !m.style.display ? 'flex' : 'none';
  }
  window.toggleMobileMenu = toggleMobileMenu;
</script>

<!-- AUTH GATE -->
<script>
  import { supabase } from '../lib/supabase';
  import { getDisplayName, getAvatarUrl, rememberIntendedUrl, AUTH_ROUTES } from '../lib/auth';
  import {
    reconcileOnSignIn,
    installAutoSync,
    pushLocal,
    clearLocal,
    readLocal,
    markImportPrompted,
  } from '../lib/progress';

  function currentPath() {
    const here = window.location.pathname;
    return here.endsWith('/') ? here : here + '/';
  }
  function isAuthRoute(p: string) { return p.includes('/architect-zero/auth/'); }
  function isDevRoute(p: string) { return p.includes('/architect-zero/_dev/'); }

  async function applyGate() {
    const path = currentPath();
    if (isAuthRoute(path) || isDevRoute(path)) {
      document.body.classList.remove('az-gating');
      return;
    }

    const { data } = await supabase.auth.getSession();
    const session = data.session;

    if (!session) {
      rememberIntendedUrl(window.location.pathname + window.location.search);
      window.location.replace(AUTH_ROUTES.signIn);
      return;
    }

    // Authed — render the page and populate the account chip.
    document.body.classList.remove('az-gating');

    const user = session.user;
    const name = getDisplayName(user);
    const avatar = getAvatarUrl(user);
    const nameEl = document.getElementById('sb-name');
    const avatarEl = document.getElementById('sb-avatar');
    if (nameEl) nameEl.textContent = name;
    if (avatarEl) {
      if (avatar) {
        avatarEl.innerHTML = '';
        const img = document.createElement('img');
        img.src = avatar;
        img.alt = '';
        img.referrerPolicy = 'no-referrer';
        avatarEl.appendChild(img);
      } else {
        avatarEl.textContent = (name[0] || '?').toUpperCase();
      }
    }

    // Personalize any page-level greeting (e.g. dashboard hero) that
    // exposes a [data-user-name] element. First name only — fits the
    // hero typography better than "Welcome back, Venkata Sundaragiri".
    const firstName = name.split(' ')[0] || name;
    document.querySelectorAll<HTMLElement>('[data-user-name]').forEach((el) => {
      el.textContent = firstName;
    });

    // Wire the sidebar sign-out button.
    const signOutBtn = document.getElementById('sb-signout') as HTMLButtonElement | null;
    if (signOutBtn && !signOutBtn.dataset.bound) {
      signOutBtn.dataset.bound = 'true';
      signOutBtn.addEventListener('click', async () => {
        signOutBtn.disabled = true;
        // onAuthStateChange SIGNED_OUT handler clears local + redirects.
        await supabase.auth.signOut();
      });
    }

    // Cloud sync — runs once per page load. reconcileOnSignIn is idempotent
    // for the cross-device pull and merge cases.
    if (!(window as any).__azReconciledFor || (window as any).__azReconciledFor !== user.id) {
      (window as any).__azReconciledFor = user.id;
      try {
        const { promptImport } = await reconcileOnSignIn(user.id);
        if (promptImport) showImportPrompt(user.id);
      } catch (err) {
        console.warn('[az] reconcile failed', err);
      }
      installAutoSync(user.id);
    }
  }

  function showImportPrompt(userId: string) {
    const prompt = document.getElementById('az-import-prompt');
    if (!prompt) return;

    const local = readLocal();
    const list = document.getElementById('az-import-list');
    if (list) {
      list.innerHTML = '';
      const rows: Array<[string, string]> = [];
      if (local.xp > 0) rows.push(['Total XP', String(local.xp)]);
      if (local.completed.length > 0) rows.push(['Lessons completed', String(local.completed.length)]);
      if (local.mastered.length > 0) rows.push(['Flashcards mastered', String(local.mastered.length)]);
      const answered = Object.keys(local.quizHistory).length;
      if (answered > 0) rows.push(['Quiz questions answered', String(answered)]);
      if (local.streak > 0) rows.push(['Day streak', String(local.streak)]);
      for (const [k, v] of rows) {
        const li = document.createElement('li');
        const a = document.createElement('span'); a.textContent = k;
        const b = document.createElement('span'); b.textContent = v;
        li.appendChild(a); li.appendChild(b);
        list.appendChild(li);
      }
    }

    prompt.hidden = false;

    const confirm = document.getElementById('az-import-confirm') as HTMLButtonElement | null;
    const skip = document.getElementById('az-import-skip') as HTMLButtonElement | null;

    confirm?.addEventListener('click', async () => {
      if (!confirm || !skip) return;
      confirm.disabled = true; skip.disabled = true;
      confirm.textContent = 'Importing...';
      try {
        await pushLocal(userId);
        markImportPrompted();
      } catch (err) {
        console.warn('[az] import push failed', err);
      } finally {
        prompt.hidden = true;
      }
    }, { once: true });

    skip?.addEventListener('click', () => {
      clearLocal();
      markImportPrompted();
      prompt.hidden = true;
    }, { once: true });
  }

  function hasCachedSession() {
    try {
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && /^sb-.*-auth-token$/.test(k)) {
          const v = localStorage.getItem(k);
          if (v && v.indexOf('access_token') !== -1) return true;
        }
      }
    } catch { /* blocked */ }
    return false;
  }

  // Fire on initial load AND after every Astro ViewTransitions swap.
  document.addEventListener('astro:page-load', applyGate);

  // Before the new page paints, decide whether to gate or pass-through.
  // Skip the overlay during navigation when we already have a cached session
  // so authed users see no flash of "Loading..." between pages.
  document.addEventListener('astro:before-swap', (e) => {
    const target = (e as any).newDocument as Document;
    if (!target?.body) return;
    const nextPath = (target.location?.pathname || '/') + '/';
    if (nextPath.includes('/architect-zero/auth/') || nextPath.includes('/architect-zero/_dev/')) {
      target.body.classList.remove('az-gating');
      return;
    }
    if (hasCachedSession()) {
      target.body.classList.remove('az-gating');
    } else {
      target.body.classList.add('az-gating');
    }
  });

  // First load fallback (in case astro:page-load already fired before this
  // listener was attached).
  applyGate();

  supabase.auth.onAuthStateChange((event) => {
    if (event === 'SIGNED_OUT') {
      // Clear local progress + reset reconcile flag so the next user on this
      // device doesn't inherit the previous user's state.
      clearLocal();
      localStorage.removeItem('az_import_prompted');
      (window as any).__azReconciledFor = null;
      if (!isAuthRoute(currentPath())) {
        window.location.replace(AUTH_ROUTES.signIn);
      }
    }
  });
</script>

<style is:global>
  .sidebar-account-row {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 14px;
  }
  .sidebar-account {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
    padding: 8px 10px;
    border-radius: 8px;
    border: 1px solid transparent;
    color: var(--text);
    text-decoration: none;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .sidebar-account:hover {
    background: var(--bg-2);
    border-color: var(--bg-4);
  }
  .sidebar-signout {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 8px;
    color: var(--muted);
    cursor: pointer;
    transition: color 150ms ease, background 150ms ease, border-color 150ms ease;
  }
  .sidebar-signout:hover {
    color: var(--signal);
    background: var(--signal-dim);
    border-color: var(--signal-mid);
  }
  .sidebar-signout:disabled {
    opacity: 0.5;
    cursor: progress;
  }
  .sidebar-account-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--brand-gradient);
    color: white;
    font-weight: 800;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .sidebar-account-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sidebar-account-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

</body>
</html>
