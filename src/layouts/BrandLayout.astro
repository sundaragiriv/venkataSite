---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import AmbientField from '../components/brand/AmbientField.astro';

const {
  title = 'Venkata Sundaragiri - Architect Zero',
  description = 'Venkata Sundaragiri - SAP Solution Architect and AI Educator. 23 years enterprise architecture. Creator of Architect Zero.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content="Venkata Sundaragiri - Architect Zero" />
    <meta property="og:description" content="SAP is my bread and butter. AI is my future. 23 years building enterprise systems. Now building on the frontier." />
    <meta property="og:url" content="https://venkata.info" />
    <meta name="theme-color" content="#020403" />
    <ViewTransitions />
    <title>{title}</title>
  </head>
  <body class="brand-page">
    <AmbientField />
    <main class="brand-main">
      <slot />
    </main>
    <script is:inline>
      // ── Brand interactions: cursor, nav scroll state, reveals, smooth scroll ──
      // Everything is wrapped in an init function and called on every Astro
      // page-load (initial + after each ViewTransitions swap) so it survives
      // SPA navigation. State that must persist across pages (mouse position,
      // RAF id) lives on window so we never double-bind or leak frames.

      function setupBrandInteractions() {
        // NAV SCROLL STATE — bind window scroll once.
        if (!window.__azNavScrollBound) {
          window.addEventListener('scroll', () => {
            const nb = document.getElementById('navbar');
            if (nb) nb.classList.toggle('scrolled', window.scrollY > 60);
          });
          window.__azNavScrollBound = true;
        }

        // MOBILE MENU TOGGLE — element-local, re-bind per navigation.
        const menuButton = document.getElementById('navMenuButton');
        const links = document.getElementById('brandNavLinks');
        if (menuButton && !menuButton.dataset.bound) {
          menuButton.addEventListener('click', () => {
            const isOpen = links?.classList.toggle('is-open');
            menuButton.setAttribute('aria-expanded', String(Boolean(isOpen)));
          });
          menuButton.dataset.bound = 'true';
        }

        // REVEAL ON SCROLL — IntersectionObserver re-created per page.
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

        // SMOOTH SCROLL for in-page anchors. Page-local, must re-bind.
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
          if (anchor.dataset.smoothBound) return;
          anchor.dataset.smoothBound = 'true';
          anchor.addEventListener('click', (event) => {
            const id = anchor.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (target) {
              event.preventDefault();
              target.scrollIntoView({ behavior: 'smooth' });
              links?.classList.remove('is-open');
              menuButton?.setAttribute('aria-expanded', 'false');
            }
          });
        });
      }

      // Initial load + every ViewTransitions navigation.
      setupBrandInteractions();
      document.addEventListener('astro:page-load', setupBrandInteractions);
    </script>
  </body>
</html>

<style is:global>
  body.brand-page {
    /* On brand pages, the AZ "electric" tokens alias to brand indigo so
       any AZ-derived component styling that references var(--electric)
       renders in the brand palette automatically. */
    --electric: var(--brand-primary);
    --electric-dim: var(--brand-primary-dim);
    --electric-mid: var(--brand-primary-mid);
    --border: rgba(37, 99, 235, 0.18);
    background:
      radial-gradient(circle at 50% -20%, rgba(59, 130, 246, 0.09), transparent 42%),
      radial-gradient(circle at 80% 110%, rgba(37, 99, 235, 0.06), transparent 50%),
      linear-gradient(180deg, var(--bg-0), #02020a 48%, var(--bg-0));
    color: var(--text);
    font-family: 'DM Sans', system-ui, sans-serif;
    overflow-x: hidden;
  }

  body.brand-page::before {
    display: none;
  }

  .brand-main {
    position: relative;
    z-index: 2;
  }

  .brand-ambient {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .brand-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(59, 130, 246, 0.10) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.10) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, black, transparent 82%);
    opacity: 0.42;
  }

  .brand-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.9;
    animation: brandOrbFloat 18s var(--ease-soft) infinite alternate;
  }

  .brand-orb-1 {
    width: 680px;
    height: 680px;
    top: -260px;
    right: -160px;
    background: conic-gradient(from 120deg, rgba(59, 130, 246, 0.20), rgba(37, 99, 235, 0.08), rgba(244, 63, 94, 0.08), rgba(59, 130, 246, 0.20));
  }

  .brand-orb-2 {
    width: 460px;
    height: 460px;
    bottom: -170px;
    left: -130px;
    background: conic-gradient(from 250deg, rgba(37, 99, 235, 0.16), rgba(234, 179, 8, 0.07), transparent, rgba(37, 99, 235, 0.16));
    animation-delay: -7s;
  }

  .brand-orb-3 {
    width: 360px;
    height: 360px;
    top: 36%;
    left: 54%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.10), transparent 68%);
    animation-delay: -12s;
  }

  .brand-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.055'/%3E%3C/svg%3E");
    opacity: 0.5;
  }

  nav.brand-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(180deg, rgba(2, 4, 3, 0.95), rgba(2, 4, 3, 0));
    border-bottom: 1px solid transparent;
    backdrop-filter: blur(14px);
    transition: border-color 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }

  nav.brand-nav.scrolled {
    border-bottom-color: var(--border);
    background: rgba(2, 4, 3, 0.82);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 20px;
    letter-spacing: 3px;
    color: var(--white);
  }

  .nav-logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand);
    box-shadow: 0 0 14px var(--brand);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-link,
  .nav-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out), background 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .nav-link {
    color: var(--subtle);
  }

  .nav-link:hover {
    color: var(--brand);
  }

  .nav-cta {
    color: var(--brand);
    padding: 8px 20px;
    border: 1px solid var(--brand-mid);
    border-radius: 4px;
    background: var(--brand-dim);
  }

  .nav-cta:hover {
    background: var(--brand);
    color: var(--black);
    transform: translateY(-1px);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 6px;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .nav-hamburger span {
    width: 24px;
    height: 2px;
    background: var(--text);
    display: block;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 100px 40px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero > .brand-ambient {
    position: absolute;
    z-index: 0;
  }

  .hero > .brand-ambient .brand-grid-bg,
  .hero > .brand-ambient .brand-orb,
  .hero > .brand-ambient .brand-noise {
    opacity: 0;
  }

  .hero-content,
  .brand-section {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-content,
  .scroll-hint {
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 80px;
    align-items: center;
  }

  .hero-eyebrow,
  .section-eyebrow,
  .az-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--brand);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    animation: fadeUp 0.6s var(--ease-out) both;
  }

  .hero-eyebrow::before,
  .az-label::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--brand);
  }

  .hero-name {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(56px, 8vw, 100px);
    color: var(--white);
    letter-spacing: 2px;
    line-height: 0.92;
    margin-bottom: 8px;
    animation: fadeUp 0.6s 0.1s var(--ease-out) both;
  }

  .hero-name-electric,
  .section-title span,
  .az-title span,
  .contact-heading span,
  .footer-logo span {
    color: var(--brand);
  }

  .hero-title {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(20px, 3vw, 32px);
    color: var(--subtle);
    letter-spacing: 3px;
    margin-bottom: 32px;
    animation: fadeUp 0.6s 0.2s var(--ease-out) both;
  }

  .hero-statement {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 17px;
    font-weight: 300;
    color: var(--text);
    line-height: 1.7;
    letter-spacing: 0.005em;
    max-width: 560px;
    margin-bottom: 40px;
    animation: fadeUp 0.6s 0.3s var(--ease-out) both;
  }

  .hero-statement strong {
    color: var(--white);
    font-weight: 700;
  }

  .hero-statement em {
    color: var(--brand);
    font-style: normal;
    font-weight: 600;
  }

  .hero-chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 44px;
    animation: fadeUp 0.6s 0.4s var(--ease-out) both;
  }

  .chip {
    padding: 5px 14px;
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .chip-electric {
    background: var(--brand-dim);
    border: 1px solid var(--brand-mid);
    color: var(--brand);
  }

  .chip-signal {
    background: var(--signal-dim);
    border: 1px solid rgba(244, 63, 94, 0.32);
    color: var(--signal);
  }

  .chip-gold {
    background: var(--gold-dim);
    border: 1px solid rgba(234, 179, 8, 0.32);
    color: var(--gold);
  }

  .chip-muted {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    color: var(--subtle);
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.5s var(--ease-out) both;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 4px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 16px;
    letter-spacing: 2px;
    transition: transform 0.2s var(--ease-out), background 0.2s var(--ease-out), color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }

  .btn-primary {
    background: var(--brand);
    color: var(--black);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg, transparent 20%, rgba(255, 255, 255, 0.15), transparent 80%);
    transform: translateX(-120%);
    transition: transform 0.6s var(--ease-out);
    pointer-events: none;
  }

  .btn-primary:hover {
    background: var(--white);
    transform: translateY(-2px);
  }

  .btn-primary:hover::before {
    transform: translateX(120%);
  }

  .btn-secondary {
    color: var(--text);
    border: 1px solid var(--border);
    background: transparent;
  }

  .btn-secondary:hover {
    border-color: var(--brand);
    color: var(--brand);
    transform: translateY(-2px);
  }

  .hero-avatar {
    position: relative;
    animation: fadeUp 0.6s 0.3s var(--ease-out) both;
  }

  .avatar-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 4px;
    background: linear-gradient(145deg, rgba(59, 130, 246, 0.10), rgba(255, 255, 255, 0.02));
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .avatar-frame::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(59, 130, 246, 0.10);
  }

  .avatar-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
    z-index: 0;
    /* Old-photo / disconnected-terminal feel: nearly monochrome, sepia-tinged,
       darker, with a subtle flicker as if the signal is degrading. */
    filter: grayscale(0.88) sepia(0.18) contrast(1.18) brightness(0.72);
    animation: avatar-flicker 7s linear infinite;
  }

  /* Cyan-tint wash + bottom darkening so captions remain readable. */
  .avatar-tint {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, transparent 35%, rgba(4, 4, 10, 0.90) 100%),
      linear-gradient(145deg, rgba(6, 182, 212, 0.20), rgba(4, 4, 10, 0.30));
  }

  /* CRT scanlines across the photo. */
  .avatar-scanlines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      180deg,
      transparent 0px,
      transparent 2px,
      rgba(0, 0, 0, 0.42) 3px,
      rgba(0, 0, 0, 0.42) 4px
    );
    opacity: 0.58;
    mix-blend-mode: multiply;
  }

  /* Animated static noise (fractal-noise SVG, stepping shift = flickery TV). */
  .avatar-noise {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.55'/%3E%3C/svg%3E");
    opacity: 0.28;
    mix-blend-mode: overlay;
    animation: avatar-noise-shift 0.32s steps(2) infinite;
  }

  /* Vignette so corners go dark, like an old monitor. */
  .avatar-vignette {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      transparent 38%,
      rgba(4, 4, 10, 0.72) 100%
    );
  }

  /* REC indicator — top-right, pulsing red. Signals "surveillance camera". */
  .avatar-rec {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    background: rgba(4, 4, 10, 0.78);
    border: 1px solid rgba(244, 63, 94, 0.45);
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: #f43f5e;
    text-transform: uppercase;
  }
  .avatar-rec-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f43f5e;
    box-shadow: 0 0 6px rgba(244, 63, 94, 0.7);
    animation: avatar-rec-pulse 1.4s ease-in-out infinite;
  }
  .avatar-rec-label { font-weight: 800; }

  /* Channel / timestamp feed text — top-left, faint. */
  .avatar-feed {
    position: absolute;
    top: 18px;
    left: 16px;
    z-index: 5;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: rgba(6, 182, 212, 0.7);
    text-transform: uppercase;
  }

  .avatar-caption {
    position: absolute;
    left: 20px;
    right: 20px;
    bottom: 64px;
    z-index: 6;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .avatar-caption-name {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 16px;
    letter-spacing: 2.5px;
    color: var(--white);
    line-height: 1;
    text-shadow: 0 0 6px rgba(4, 4, 10, 0.9);
  }

  .avatar-caption-role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--brand);
    text-transform: uppercase;
  }

  @keyframes avatar-flicker {
    0%, 96%, 98%, 100% { opacity: 1; }
    97%   { opacity: 0.82; }
    97.5% { opacity: 0.94; }
  }

  @keyframes avatar-noise-shift {
    0%   { transform: translate(0, 0); }
    50%  { transform: translate(-1px, 1px); }
    100% { transform: translate(1px, -1px); }
  }

  @keyframes avatar-rec-pulse {
    0%, 100% { opacity: 1;    box-shadow: 0 0 6px rgba(244, 63, 94, 0.7);  }
    50%      { opacity: 0.35; box-shadow: 0 0 2px rgba(244, 63, 94, 0.2);  }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-photo,
    .avatar-noise,
    .avatar-rec-dot {
      animation: none;
    }
  }

  .avatar-label,
  .status-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--subtle);
    text-transform: uppercase;
  }

  .avatar-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    border-color: var(--brand);
    border-style: solid;
    z-index: 5;
  }

  .avatar-corner-tl { top: 12px; left: 12px; border-width: 2px 0 0 2px; }
  .avatar-corner-tr { top: 12px; right: 12px; border-width: 2px 2px 0 0; }
  .avatar-corner-bl { bottom: 12px; left: 12px; border-width: 0 0 2px 2px; }
  .avatar-corner-br { right: 12px; bottom: 12px; border-width: 0 2px 2px 0; }

  .avatar-scanline {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--brand-mid), transparent);
    animation: scan 3s linear infinite;
    z-index: 5;
  }

  .avatar-status {
    position: absolute;
    right: 16px;
    bottom: 16px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: rgba(2, 4, 3, 0.88);
    z-index: 6;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand);
    box-shadow: 0 0 8px var(--brand);
    animation: pulse 2s infinite;
  }

  .status-text {
    color: var(--brand);
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeUp 0.6s 0.8s var(--ease-out) both;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, var(--brand), transparent);
    animation: scrollPulse 2s infinite;
  }

  .scroll-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
  }

  .brand-section {
    padding: 100px 40px;
  }

  .section-header {
    margin-bottom: 56px;
  }

  body.brand-page .section-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    color: var(--brand);
  }

  body.brand-page .section-eyebrow::after {
    content: '';
    flex: 0 0 40px;
    height: 1px;
    background: var(--brand);
  }

  body.brand-page .section-title {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(36px, 5vw, 64px);
    color: var(--white);
    letter-spacing: 2px;
    line-height: 0.95;
    margin: 0;
  }

  .story-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }

  .story-half,
  .contact-left,
  .contact-right {
    padding: 48px;
  }

  .story-half-left,
  .contact-left {
    border-right: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.035);
  }

