---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import AmbientField from '../components/brand/AmbientField.astro';

const {
  title = 'Venkata Sundaragiri - Architect Zero',
  description = 'Venkata Sundaragiri - SAP Solution Architect and AI Educator. 23 years enterprise architecture. Creator of Architect Zero.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content="Venkata Sundaragiri - Architect Zero" />
    <meta property="og:description" content="SAP is my bread and butter. AI is my future. 23 years building enterprise systems. Now building on the frontier." />
    <meta property="og:url" content="https://venkata.info" />
    <meta name="theme-color" content="#020403" />
    <ViewTransitions />
    <title>{title}</title>
  </head>
  <body class="brand-page">
    <div id="cursor" class="cursor"></div>
    <div id="cursorRing" class="cursor-ring"></div>
    <AmbientField />
    <main class="brand-main">
      <slot />
    </main>
    <script is:inline>
      const cursor = document.getElementById('cursor');
      const ring = document.getElementById('cursorRing');
      let mx = 0;
      let my = 0;
      let rx = 0;
      let ry = 0;

      if (cursor && ring && window.matchMedia('(pointer: fine)').matches) {
        document.addEventListener('mousemove', (event) => {
          mx = event.clientX;
          my = event.clientY;
          cursor.style.left = `${mx - 4}px`;
          cursor.style.top = `${my - 4}px`;
        });

        const animateRing = () => {
          rx += (mx - rx) * 0.12;
          ry += (my - ry) * 0.12;
          ring.style.left = `${rx - 16}px`;
          ring.style.top = `${ry - 16}px`;
          requestAnimationFrame(animateRing);
        };
        animateRing();

        document.querySelectorAll('a, button').forEach((el) => {
          el.addEventListener('mouseenter', () => {
            cursor.style.transform = 'scale(2.5)';
            ring.classList.add('is-hovering');
          });
          el.addEventListener('mouseleave', () => {
            cursor.style.transform = 'scale(1)';
            ring.classList.remove('is-hovering');
          });
        });
      }

      const navbar = document.getElementById('navbar');
      window.addEventListener('scroll', () => {
        navbar?.classList.toggle('scrolled', window.scrollY > 60);
      });

      const menuButton = document.getElementById('navMenuButton');
      const links = document.getElementById('brandNavLinks');
      menuButton?.addEventListener('click', () => {
        const isOpen = links?.classList.toggle('is-open');
        menuButton.setAttribute('aria-expanded', String(Boolean(isOpen)));
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (event) => {
          const id = anchor.getAttribute('href');
          if (!id || id === '#') return;
          const target = document.querySelector(id);
          if (target) {
            event.preventDefault();
            target.scrollIntoView({ behavior: 'smooth' });
            links?.classList.remove('is-open');
            menuButton?.setAttribute('aria-expanded', 'false');
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  body.brand-page {
    --black: var(--bg-0);
    --deep: var(--bg-1);
    --surface: var(--bg-2);
    --card: var(--bg-3);
    --border: rgba(154, 255, 190, 0.14);
    --muted: #688073;
    --subtle: #a5b7ad;
    --text: #e8f3ed;
    --white: #ffffff;
    --electric: var(--brand);
    --electric-dim: var(--brand-dim);
    --electric-mid: var(--brand-mid);
    --signal: #ff4f7e;
    --signal-dim: rgba(255, 79, 126, 0.14);
    --gold: #ffd166;
    --gold-dim: rgba(255, 209, 102, 0.14);
    --green: var(--brand);
    background:
      radial-gradient(circle at 50% -20%, rgba(0, 255, 65, 0.10), transparent 38%),
      linear-gradient(180deg, var(--bg-0), var(--bg-1) 42%, var(--bg-0));
    color: var(--text);
    font-family: 'DM Sans', 'Barlow', system-ui, sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  body.brand-page::before {
    display: none;
  }

  .brand-main {
    position: relative;
    z-index: 2;
  }

  .cursor,
  .cursor-ring {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    display: block;
  }

  .cursor {
    width: 8px;
    height: 8px;
    background: var(--brand);
    border-radius: 50%;
    transition: transform 0.15s var(--ease-out);
    mix-blend-mode: screen;
  }

  .cursor-ring {
    width: 32px;
    height: 32px;
    border: 1px solid var(--brand-mid);
    border-radius: 50%;
    transition: width 0.2s var(--ease-out), height 0.2s var(--ease-out), margin 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }

  .cursor-ring.is-hovering {
    width: 48px;
    height: 48px;
    margin-left: -8px;
    margin-top: -8px;
    border-color: var(--brand);
  }

  .brand-ambient {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .brand-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 255, 65, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 65, 0.08) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, black, transparent 82%);
    opacity: 0.42;
  }

  .brand-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(10px);
    opacity: 0.9;
    animation: brandOrbFloat 18s var(--ease-soft) infinite alternate;
  }

  .brand-orb-1 {
    width: 680px;
    height: 680px;
    top: -260px;
    right: -160px;
    background: conic-gradient(from 120deg, rgba(0, 255, 65, 0.18), rgba(138, 255, 193, 0.04), rgba(255, 79, 126, 0.08), rgba(0, 255, 65, 0.18));
  }

  .brand-orb-2 {
    width: 460px;
    height: 460px;
    bottom: -170px;
    left: -130px;
    background: conic-gradient(from 250deg, rgba(0, 255, 65, 0.14), rgba(255, 209, 102, 0.07), transparent, rgba(0, 255, 65, 0.14));
    animation-delay: -7s;
  }

  .brand-orb-3 {
    width: 360px;
    height: 360px;
    top: 36%;
    left: 54%;
    background: radial-gradient(circle, rgba(0, 255, 65, 0.08), transparent 68%);
    animation-delay: -12s;
  }

  .brand-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.055'/%3E%3C/svg%3E");
    opacity: 0.5;
  }

  nav.brand-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(180deg, rgba(2, 4, 3, 0.95), rgba(2, 4, 3, 0));
    border-bottom: 1px solid transparent;
    backdrop-filter: blur(14px);
    transition: border-color 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }

  nav.brand-nav.scrolled {
    border-bottom-color: var(--border);
    background: rgba(2, 4, 3, 0.82);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 20px;
    letter-spacing: 3px;
    color: var(--white);
  }

  .nav-logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand);
    box-shadow: 0 0 14px var(--brand);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-link,
  .nav-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out), background 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .nav-link {
    color: var(--subtle);
  }

  .nav-link:hover {
    color: var(--brand);
  }

  .nav-cta {
    color: var(--brand);
    padding: 8px 20px;
    border: 1px solid var(--brand-mid);
    border-radius: 4px;
    background: var(--brand-dim);
  }

  .nav-cta:hover {
    background: var(--brand);
    color: var(--black);
    transform: translateY(-1px);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 6px;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .nav-hamburger span {
    width: 24px;
    height: 2px;
    background: var(--text);
    display: block;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 100px 40px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero > .brand-ambient {
    position: absolute;
    z-index: 0;
  }

  .hero > .brand-ambient .brand-grid-bg,
  .hero > .brand-ambient .brand-orb,
  .hero > .brand-ambient .brand-noise {
    opacity: 0;
  }

  .hero-content,
  .brand-section {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-content,
  .scroll-hint {
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 80px;
    align-items: center;
  }

  .hero-eyebrow,
  .section-eyebrow,
  .az-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--brand);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    animation: fadeUp 0.6s var(--ease-out) both;
  }

  .hero-eyebrow::before,
  .az-label::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--brand);
  }

  .hero-name {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(56px, 8vw, 100px);
    color: var(--white);
    letter-spacing: 2px;
    line-height: 0.92;
    margin-bottom: 8px;
    animation: fadeUp 0.6s 0.1s var(--ease-out) both;
  }

  .hero-name-electric,
  .section-title span,
  .az-title span,
  .contact-heading span,
  .footer-logo span {
    color: var(--brand);
  }

  .hero-title {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(20px, 3vw, 32px);
    color: var(--subtle);
    letter-spacing: 3px;
    margin-bottom: 32px;
    animation: fadeUp 0.6s 0.2s var(--ease-out) both;
  }

  .hero-statement {
    font-size: 18px;
    font-weight: 300;
    color: var(--text);
    line-height: 1.8;
    max-width: 560px;
    margin-bottom: 40px;
    animation: fadeUp 0.6s 0.3s var(--ease-out) both;
  }

  .hero-statement strong {
    color: var(--white);
    font-weight: 700;
  }

  .hero-statement em {
    color: var(--brand);
    font-style: normal;
    font-weight: 600;
  }

  .hero-chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 44px;
    animation: fadeUp 0.6s 0.4s var(--ease-out) both;
  }

  .chip {
    padding: 5px 14px;
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .chip-electric {
    background: var(--brand-dim);
    border: 1px solid var(--brand-mid);
    color: var(--brand);
  }

  .chip-signal {
    background: var(--signal-dim);
    border: 1px solid rgba(255, 79, 126, 0.32);
    color: var(--signal);
  }

  .chip-gold {
    background: var(--gold-dim);
    border: 1px solid rgba(255, 209, 102, 0.32);
    color: var(--gold);
  }

  .chip-muted {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    color: var(--subtle);
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.5s var(--ease-out) both;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 4px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 16px;
    letter-spacing: 2px;
    transition: transform 0.2s var(--ease-out), background 0.2s var(--ease-out), color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }

  .btn-primary {
    background: var(--brand);
    color: var(--black);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg, transparent 20%, rgba(255, 255, 255, 0.15), transparent 80%);
    transform: translateX(-120%);
    transition: transform 0.6s var(--ease-out);
    pointer-events: none;
  }

  .btn-primary:hover {
    background: var(--white);
    transform: translateY(-2px);
  }

  .btn-primary:hover::before {
    transform: translateX(120%);
  }

  .btn-secondary {
    color: var(--text);
    border: 1px solid var(--border);
    background: transparent;
  }

  .btn-secondary:hover {
    border-color: var(--brand);
    color: var(--brand);
    transform: translateY(-2px);
  }

  .hero-avatar {
    position: relative;
    animation: fadeUp 0.6s 0.3s var(--ease-out) both;
  }

  .avatar-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 4px;
    background: linear-gradient(145deg, rgba(0, 255, 65, 0.08), rgba(255, 255, 255, 0.02));
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
  }

  .avatar-frame::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(0, 255, 65, 0.08);
  }

  .avatar-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 40px;
    text-align: center;
  }

  .avatar-initials {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 88px;
    letter-spacing: 4px;
    color: var(--brand);
    opacity: 0.22;
    line-height: 1;
  }

  .avatar-label,
  .status-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--subtle);
    text-transform: uppercase;
  }

  .avatar-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    border-color: var(--brand);
    border-style: solid;
  }

  .avatar-corner-tl { top: 12px; left: 12px; border-width: 2px 0 0 2px; }
  .avatar-corner-tr { top: 12px; right: 12px; border-width: 2px 2px 0 0; }
  .avatar-corner-bl { bottom: 12px; left: 12px; border-width: 0 0 2px 2px; }
  .avatar-corner-br { right: 12px; bottom: 12px; border-width: 0 2px 2px 0; }

  .avatar-scanline {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--brand-mid), transparent);
    animation: scan 3s linear infinite;
  }

  .avatar-status {
    position: absolute;
    right: 16px;
    bottom: 16px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: rgba(2, 4, 3, 0.88);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand);
    box-shadow: 0 0 8px var(--brand);
    animation: pulse 2s infinite;
  }

  .status-text {
    color: var(--brand);
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeUp 0.6s 0.8s var(--ease-out) both;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, var(--brand), transparent);
    animation: scrollPulse 2s infinite;
  }

  .scroll-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
  }

  .brand-section {
    padding: 100px 40px;
  }

  .section-header {
    margin-bottom: 56px;
  }

  body.brand-page .section-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    color: var(--brand);
  }

  body.brand-page .section-eyebrow::after {
    content: '';
    flex: 0 0 40px;
    height: 1px;
    background: var(--brand);
  }

  body.brand-page .section-title {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(36px, 5vw, 64px);
    color: var(--white);
    letter-spacing: 2px;
    line-height: 0.95;
    margin: 0;
  }

  .story-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }

  .story-half,
  .contact-left,
  .contact-right {
    padding: 48px;
  }

  .story-half-left,
  .contact-left {
    border-right: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.035);
  }

  .story-label,
  .bc-tag,
  .skill-cat-label,
  .contact-link-label,
  .footer-copy,
  .footer-tql,
  .app-mockup-badge,
  .az-ep-domain {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .story-label {
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .story-label-bread { color: var(--gold); }
  .story-label-future { color: var(--brand); }

  .story-num {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 72px;
    opacity: 0.12;
    line-height: 1;
    margin-bottom: 8px;
  }

  .story-half-left .story-num,
  .story-half-left .story-heading {
    color: var(--gold);
  }

  .story-half-right .story-num,
  .story-half-right .story-heading {
    color: var(--brand);
  }

  .story-heading,
  .bc-title {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 32px;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .story-body,
  .bc-desc,
  .contact-body {
    font-size: 15px;
    font-weight: 300;
    color: var(--subtle);
    line-height: 1.85;
  }

  .story-body strong,
  .bc-title,
  .az-ep-title {
    color: var(--text);
    font-weight: 600;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-top: 48px;
  }

  .stat-block {
    background: rgba(255, 255, 255, 0.035);
    padding: 32px 24px;
    text-align: center;
    transition: background 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .stat-block:hover {
    background: rgba(0, 255, 65, 0.05);
  }

  .stat-num {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 52px;
    line-height: 1;
    color: var(--white);
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .stat-num .stat-affix {
    color: var(--brand);
  }

  .stat-num .stat-value {
    color: var(--white);
  }

  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .building-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .building-card,
  .skill-category,
  .app-mockup {
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .building-card {
    padding: 32px;
    transition: transform 250ms var(--ease-snap), border-color 250ms ease, box-shadow 250ms ease;
    position: relative;
    overflow: hidden;
  }

  .building-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
